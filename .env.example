# ─── Required ────────────────────────────────────────────────────
# Any OpenAI-compatible LLM gateway. Examples:
#   OpenAI:      https://api.openai.com/v1                (default)
#   OpenRouter:  https://openrouter.ai/api/v1
#   Requesty:    https://router.requesty.ai/v1
#   Together:    https://api.together.xyz/v1
#   Ollama:      http://localhost:11434/v1
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Powers the search_web and read_url tools.
# Get a key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# ─── Models (optional — override the defaults if you like) ───────
# Use whatever model IDs your gateway exposes. The brain MUST support
# OpenAI-style tool/function calling.
# BRAIN_MODEL=anthropic/claude-sonnet-4-5
# FAST_MODEL=google/gemini-2.5-flash
# READER_MODEL=xai/grok-4-fast

# ─── Budget caps (optional) ──────────────────────────────────────
# MAX_REACT_STEPS=30
# MAX_READS=25
# MAX_CHARTS=4
# MAX_SEARCH_RESULTS=10
# READER_ENABLED=true

# ─── Web server (optional) ───────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
